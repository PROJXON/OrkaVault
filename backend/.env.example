# Backend Environment Variables
# Copy this file to .env and fill in your values. Never commit .env!

# PostgreSQL connection string (e.g., from Neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/orkavault

# Secret key for signing JWTs (use a long, random string)
JWT_SECRET=replace_with_a_strong_random_secret

# Allowed origin for CORS (your frontend URL)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=5001
