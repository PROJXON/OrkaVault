# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
local_master.key
.dev-secret-store.json

# ─── Database Files (local dev only) ─────────────────────────────────────────
prisma/*.db
prisma/*.db-journal
.env.*
!.env.example
local_master.key
.dev-secret-store.json

# ─── Build Output ─────────────────────────────────────────────────────────────
dist/

# ─── Node Modules ─────────────────────────────────────────────────────────────
node_modules/

# ─── Uploads (user-generated files - should use cloud storage in prod) ────────
uploads/

# ─── Prisma Generated Client (re-generated on build) ─────────────────────────
