{
  "name": "orkavault-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development electron .\"",
    "build:electron": "electron-builder build --win --publish never"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.2.8"
  },
  "build": {
    "appId": "com.orkavault.desktop",
    "productName": "OrkaVault Desktop",
    "win": {
      "target": "portable",
      "icon": "src/assets/OrkaVault.png"
    },
    "directories": {
      "output": "dist-desktop"
    }
  }
}
